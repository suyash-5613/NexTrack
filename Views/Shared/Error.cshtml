@{
    ViewData["Title"] = "Error";
}

<div class="d-flex flex-column align-items-center justify-content-center py-5">
    <div class="text-center">
        <div class="empty-state-icon-lg mx-auto mb-3">
            <i class="bi bi-exclamation-triangle fs-2 text-slate-400"></i>
        </div>
        <h2 class="h5 fw-bold text-slate-900">An error occurred</h2>
        <p class="text-slate-500 small">An error occurred while processing your request. Please try again.</p>
        <a href="/" class="btn btn-primary-indigo mt-2">Go to Dashboard</a>
    </div>
</div>
