<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - NexTrack</title>
    <meta name="description" content="NexTrack Item Processing System - Manage, process, and track items efficiently." />

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    @if (Context.Session.GetString("UserEmail") != null)
    {
        <div class="d-flex vh-100">
            <!-- Sidebar -->
            <aside class="sidebar">
                <div class="sidebar-logo">
                    <div class="d-flex align-items-center gap-2 text-indigo">
                        <i class="bi bi-hexagon-fill fs-4"></i>
                        <span class="fw-bold fs-5" style="letter-spacing: -0.5px;">NexTrack</span>
                    </div>
                </div>

                <nav class="sidebar-nav">
                    @{
                        var currentPath = Context.Request.Path.Value?.ToLower() ?? "";
                        var navItems = new[]
                        {
                            new { Href = "/Items", Icon = "bi-box-seam", Label = "Item Management", IsActive = currentPath == "/items" || currentPath == "/" },
                            new { Href = "/Items/Process", Icon = "bi-diagram-3", Label = "Process Item", IsActive = currentPath.Contains("/process") },
                            new { Href = "/Items/Tree", Icon = "bi-share", Label = "Tree Structure", IsActive = currentPath.Contains("/tree") },
                            new { Href = "/Items/Processed", Icon = "bi-list-check", Label = "Processed Items", IsActive = currentPath.Contains("/processed") },
                        };
                    }
                    @foreach (var item in navItems)
                    {
                        <a href="@item.Href"
                           class="nav-item @(item.IsActive ? "active" : "")">
                            <i class="bi @item.Icon"></i>
                            @item.Label
                        </a>
                    }
                </nav>

                <div class="sidebar-footer">
                    <div class="d-flex align-items-center justify-content-between">
                        <div class="d-flex align-items-center gap-2">
                            <div class="user-avatar">
                                @(Context.Session.GetString("UserEmail")?.Substring(0, 1).ToUpper())
                            </div>
                            <span class="text-slate-700 small fw-medium text-truncate" style="max-width: 120px;">
                                @Context.Session.GetString("UserEmail")
                            </span>
                        </div>
                        <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-icon text-slate-400" title="Logout">
                                <i class="bi bi-box-arrow-right"></i>
                            </button>
                        </form>
                    </div>
                </div>
            </aside>

            <!-- Main Content -->
            <main class="flex-grow-1 overflow-auto bg-slate-50">
                <div class="content-area">
                    @RenderBody()
                </div>
            </main>
        </div>
    }
    else
    {
        @RenderBody()
    }

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Custom JS -->
    <script src="~/js/site.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
