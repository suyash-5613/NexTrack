@model NexTrack.Models.LoginViewModel
@{
    ViewData["Title"] = "Login";
    Layout = "_Layout";
}

<div class="min-vh-100 bg-slate-50 d-flex flex-column justify-content-center py-5">
    <div class="mx-auto w-100" style="max-width: 420px;">
        <!-- Logo -->
        <div class="text-center mb-4">
            <div class="d-inline-flex p-3 bg-white rounded-4 shadow-sm border" style="border-color: var(--slate-100) !important;">
                <i class="bi bi-hexagon-fill text-indigo" style="font-size: 3rem;"></i>
            </div>
            <h2 class="mt-3 fw-800 text-slate-900" style="font-size: 1.875rem; letter-spacing: -0.5px;">Welcome back</h2>
            <p class="text-slate-500 small mt-1">Sign in to your account to continue</p>
        </div>

        <!-- Login Card -->
        <div class="bg-white py-4 px-4 shadow-card rounded-4 border" style="border-color: var(--slate-100) !important;">
            <form asp-action="Login" asp-controller="Account" method="post" class="d-flex flex-column gap-4">
                @Html.AntiForgeryToken()

                <!-- Validation Summary -->
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert-error d-flex align-items-start gap-2 p-3 rounded-3">
                        <i class="bi bi-exclamation-circle text-danger mt-1"></i>
                        <div>
                            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                            {
                                <p class="small text-danger mb-0">@error.ErrorMessage</p>
                            }
                        </div>
                    </div>
                }

                <!-- Email -->
                <div>
                    <label asp-for="Email" class="form-label small fw-medium text-slate-700">Email address</label>
                    <input asp-for="Email" type="email" class="form-control form-control-custom"
                           placeholder="admin@example.com" autocomplete="email" />
                </div>

                <!-- Password -->
                <div>
                    <label asp-for="Password" class="form-label small fw-medium text-slate-700">Password</label>
                    <input asp-for="Password" type="password" class="form-control form-control-custom"
                           placeholder="••••••••" autocomplete="current-password" />
                </div>

                <!-- Submit -->
                <button type="submit" class="btn btn-primary-indigo w-100 d-flex justify-content-center align-items-center gap-2 py-3">
                    <i class="bi bi-box-arrow-in-right"></i>
                    Sign in
                </button>
            </form>
        </div>
    </div>
</div>
