@model List<NexTrack.Models.Item>
@{
    ViewData["Title"] = "Item Management";
    var search = ViewBag.Search as string ?? "";
    var status = ViewBag.Status as string ?? "all";
}

<div class="d-flex flex-column gap-4 fade-in">
    <!-- Header -->
    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-3">
        <div>
            <h1 class="h4 fw-bold text-slate-900 mb-1" style="letter-spacing: -0.5px;">Item Management</h1>
            <p class="text-slate-500 small mb-0">Manage all root items and track their processing status.</p>
        </div>
        <button type="button" class="btn btn-primary-indigo d-inline-flex align-items-center gap-2"
                data-bs-toggle="modal" data-bs-target="#itemModal" onclick="openCreateModal()">
            <i class="bi bi-plus-lg"></i>
            Add Item
        </button>
    </div>

    <!-- Alerts -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success-custom d-flex align-items-center gap-2 py-3" role="alert">
            <i class="bi bi-check-circle-fill text-success"></i>
            <span class="small">@TempData["Success"]</span>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert-error d-flex align-items-center gap-2 p-3 rounded-3" role="alert">
            <i class="bi bi-exclamation-circle text-danger"></i>
            <span class="small text-danger">@TempData["Error"]</span>
        </div>
    }

    <!-- Table Card -->
    <div class="card card-custom">
        <!-- Toolbar -->
        <div class="card-toolbar">
            <form method="get" asp-action="Index" class="d-flex flex-column flex-sm-row gap-3 w-100 justify-content-between">
                <div class="position-relative" style="max-width: 350px; width: 100%;">
                    <i class="bi bi-search position-absolute text-slate-400" style="left: 14px; top: 50%; transform: translateY(-50%);"></i>
                    <input type="text" name="search" value="@search" placeholder="Search items by name..."
                           class="form-control form-control-custom ps-5" />
                </div>

                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-funnel text-slate-400"></i>
                    <select name="status" class="form-select form-select-custom" onchange="this.form.submit()">
                        <option value="all" selected="@(status == "all")">All Statuses</option>
                        <option value="pending" selected="@(status == "pending")">Pending</option>
                        <option value="processed" selected="@(status == "processed")">Processed</option>
                    </select>
                </div>
            </form>
        </div>

        <!-- Table -->
        <div class="table-responsive">
            <table class="table table-custom mb-0">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Weight</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5">
                                <div class="d-flex flex-column align-items-center gap-3">
                                    <div class="empty-state-icon">
                                        <i class="bi bi-search fs-4 text-slate-400"></i>
                                    </div>
                                    <p class="text-slate-500 mb-0">No items found matching your criteria.</p>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr class="table-row-hover">
                                <td>
                                    <div class="fw-medium text-slate-900">@item.Name</div>
                                    <div class="small text-slate-500 mt-1 font-monospace">ID: @item.Id</div>
                                </td>
                                <td class="text-slate-600 fw-medium">@item.Weight kg</td>
                                <td>
                                    @if (item.Status == "processed")
                                    {
                                        <span class="badge-status badge-processed">
                                            <i class="bi bi-check-circle-fill"></i> Processed
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge-status badge-pending">
                                            <i class="bi bi-clock-fill"></i> Pending
                                        </span>
                                    }
                                </td>
                                <td class="text-end">
                                    <div class="d-flex justify-content-end gap-1 action-buttons">
                                        <button type="button" class="btn btn-icon"
                                                onclick="openEditModal(@item.Id, '@item.Name.Replace("'", "\\'")' , @item.Weight)"
                                                title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <form asp-action="Delete" method="post" class="d-inline"
                                              onsubmit="return confirm('Are you sure you want to delete this item? This will also delete all its child items.');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="btn btn-icon btn-icon-danger" title="Delete">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <!-- Footer -->
        <div class="card-footer-custom">
            <span>Showing @Model.Count items</span>
        </div>
    </div>
</div>

<!-- Add/Edit Item Modal -->
<div class="modal fade" id="itemModal" tabindex="-1" aria-labelledby="itemModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content modal-custom">
            <div class="modal-header modal-header-custom">
                <h5 class="modal-title fw-semibold text-slate-900" id="itemModalLabel">Add New Item</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="itemForm" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" id="itemId" name="id" value="" />
                <div class="modal-body modal-body-custom">
                    <div class="mb-4">
                        <label for="itemName" class="form-label small fw-medium text-slate-700">Item Name</label>
                        <input type="text" id="itemName" name="name" class="form-control form-control-custom"
                               placeholder="e.g., Raw Material Batch D" required />
                    </div>
                    <div>
                        <label for="itemWeight" class="form-label small fw-medium text-slate-700">Weight (kg)</label>
                        <input type="number" id="itemWeight" name="weight" class="form-control form-control-custom"
                               placeholder="0.00" min="0.01" step="0.01" required />
                    </div>
                </div>
                <div class="modal-footer modal-footer-custom">
                    <button type="button" class="btn btn-secondary-custom" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary-indigo" id="modalSubmitBtn">Create Item</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function openCreateModal() {
        document.getElementById('itemModalLabel').textContent = 'Add New Item';
        document.getElementById('modalSubmitBtn').textContent = 'Create Item';
        document.getElementById('itemForm').action = '@Url.Action("Create", "Items")';
        document.getElementById('itemId').value = '';
        document.getElementById('itemName').value = '';
        document.getElementById('itemWeight').value = '';
    }

    function openEditModal(id, name, weight) {
        document.getElementById('itemModalLabel').textContent = 'Edit Item';
        document.getElementById('modalSubmitBtn').textContent = 'Save Changes';
        document.getElementById('itemForm').action = '@Url.Action("Edit", "Items")';
        document.getElementById('itemId').value = id;
        document.getElementById('itemName').value = name;
        document.getElementById('itemWeight').value = weight;
        var modal = new bootstrap.Modal(document.getElementById('itemModal'));
        modal.show();
    }
</script>
}
